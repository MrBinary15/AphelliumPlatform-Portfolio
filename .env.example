# Aphellium Platform - Environment Template
# Copy to .env.local for local development.
# In production, set these values in Vercel Environment Variables.
# Do NOT commit real secrets.

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Translation service (optional)
TRANSLATE_API_URL=

# Google Gemini AI (required for public AI chat)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY

# Direct Postgres connection string (optional; scripts/maintenance)
DATABASE_URL=

# Metered.ca TURN servers (optional; for enhanced video call connectivity)
METERED_DOMAIN=
METERED_SECRET_KEY=
